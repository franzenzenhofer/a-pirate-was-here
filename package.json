{
  "name": "pirates-caribbean",
  "version": "1.0.0",
  "description": "The ultimate pirate map game — open-world Caribbean adventure",
  "type": "module",
  "scripts": {
    "build:version": "node scripts/write-build-version.mjs",
    "dev": "vite",
    "prebuild": "npm run build:version",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "preview": "vite preview",
    "preview:host": "vite preview --host 0.0.0.0 --port 4173",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.3.5",
    "eslint": "^9.0.0",
    "happy-dom": "^20.8.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.49.0"
  }
}
